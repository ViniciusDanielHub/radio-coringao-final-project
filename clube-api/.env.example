# Banco de dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5441/clube_db"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clube_db

# Servidor
PORT=3010
NODE_ENV=development
LOG_LEVEL=info

# CORS — lista separada por vírgula; deixe em branco para permitir todas as origens em dev
# CORS_ORIGIN=http://localhost:3000,https://meusite.com.br

# Rate limit (requisições por minuto por IP)
RATE_LIMIT_MAX=200

# Segurança — gere com: openssl rand -hex 32
CLUBE_API_KEY=troque-por-uma-chave-forte-gerada-com-openssl

# Cloudinary (upload de imagens)
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=sua-api-key
CLOUDINARY_API_SECRET=seu-api-secret
CLOUDINARY_FOLDER=clube-api

# Seed (usado apenas por npm run db:seed)
SEED_TEAM_NAME="Meu Clube"
SEED_TEAM_SHORT_NAME="MC"
