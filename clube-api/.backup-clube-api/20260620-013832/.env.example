NODE_ENV=development
PORT=3010

# Banco de dados próprio (Docker local) — porta diferente do sports_news
DATABASE_URL="postgresql://postgres:postgres@localhost:5441/clube_db"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clube_db

# CORS — coloque aqui o(s) domínio(s) do painel admin do sports-news-api
ALLOWED_ORIGINS=http://localhost:3007,http://localhost:3000

# Chave usada pela API principal (sports-news-api) para autenticar
# chamadas server-to-server nas rotas de escrita (POST/PATCH/DELETE).
# Gere uma string aleatória longa, ex: openssl rand -hex 32
CLUBE_API_KEY=troque_essa_chave_em_producao

# Dados do clube (usados no seed do Team singleton)
SEED_TEAM_NAME="Meu Clube"
SEED_TEAM_SHORT_NAME="Clube"
