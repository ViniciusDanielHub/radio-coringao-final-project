# ==============================================
# AMBIENTE
# ==============================================
NODE_ENV=development
PORT=3000

# ==============================================
# BANCO DE DADOS (Supabase - PostgreSQL)
# Cole a URL do seu projeto no Supabase
# ==============================================
DATABASE_URL="postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJETO].supabase.co:5432/postgres"

# ==============================================
# JWT (Auth)
# Gere uma string aleatória segura para produção
# ==============================================
JWT_SECRET=troque_por_uma_string_muito_segura_em_producao
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==============================================
# CLOUDINARY (Upload de imagens - grátis 25GB)
# Crie conta em cloudinary.com e copie as credenciais
# ==============================================
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
CLOUDINARY_FOLDER=sports-news

# ==============================================
# CORS - URLs permitidas
# ==============================================
ALLOWED_ORIGINS=http://localhost:3001,https://seusite.com.br

# ==============================================
# ADMIN INICIAL (usado no seed)
# ==============================================
SEED_ADMIN_EMAIL=admin@seusite.com.br
SEED_ADMIN_PASSWORD=troque_essa_senha_imediatamente
SEED_ADMIN_NAME=Administrador
